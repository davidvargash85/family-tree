{
  "name": "family-tree-backend",
  "version": "1.0.0",
  "description": "Family Tree API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:supabase": "dotenv -e .env.supabase -- prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "socket.io": "^4.8.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "zod": "^3.23.8",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0"
  }
}
