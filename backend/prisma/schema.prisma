generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")

  ownedTrees    Tree[]          @relation("TreeOwner")
  treeAccess    TreeAccess[]
  sentInvites   Invitation[]    @relation("InvitedBy")
  publications  Publication[]   @relation("PublicationCreator")
  comments      Comment[]       @relation("CommentAuthor")
}

model Tree {
  id               String   @id @default(cuid())
  name             String
  ownerId          String   @map("owner_id")
  layoutPositions  Json?    @map("layout_positions")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  owner         User          @relation("TreeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       Member[]
  relationships Relationship[]
  invitations   Invitation[]
  access        TreeAccess[]
  photos        Photo[]
  publications  Publication[]
}

model Member {
  id        String    @id @default(cuid())
  treeId    String    @map("tree_id")
  name      String
  gender    String?   @map("gender")   // "male" | "female" | "unspecified"
  birthDate DateTime? @map("birth_date")
  deathDate DateTime? @map("death_date")
  bio       String?
  photoUrl  String?   @map("photo_url")
  createdAt DateTime  @default(now()) @map("created_at")

  tree             Tree             @relation(fields: [treeId], references: [id], onDelete: Cascade)
  relsAsA          Relationship[]   @relation("MemberA")
  relsAsB          Relationship[]   @relation("MemberB")
  photoTags        PhotoTag[]
  publicationTags  PublicationTag[]
}

model Photo {
  id        String   @id @default(cuid())
  treeId    String   @map("tree_id")
  filePath  String   @map("file_path")
  caption   String?
  createdAt DateTime @default(now()) @map("created_at")

  tree         Tree          @relation(fields: [treeId], references: [id], onDelete: Cascade)
  tags        PhotoTag[]
  publication Publication?
}

model Publication {
  id              String    @id @default(cuid())
  treeId          String    @map("tree_id")
  content         String?   // text / caption
  photoId         String?   @unique @map("photo_id")
  createdById     String?   @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  lastActivityAt  DateTime? @map("last_activity_at")

  tree      Tree             @relation(fields: [treeId], references: [id], onDelete: Cascade)
  photo     Photo?            @relation(fields: [photoId], references: [id], onDelete: SetNull)
  createdBy User?             @relation("PublicationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tags      PublicationTag[]
  comments  Comment[]

  @@index([treeId])
  @@index([createdAt])
  @@index([lastActivityAt])
}

model Comment {
  id             String    @id @default(cuid())
  publicationId  String    @map("publication_id")
  authorId       String    @map("author_id")
  content        String
  parentId       String?   @map("parent_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  parent      Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]   @relation("CommentReplies")
  author      User        @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([publicationId])
  @@index([parentId])
}

model PublicationTag {
  publicationId String @map("publication_id")
  memberId      String @map("member_id")

  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([publicationId, memberId])
  @@index([publicationId])
  @@index([memberId])
}

model PhotoTag {
  photoId  String @map("photo_id")
  memberId String @map("member_id")

  photo  Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([photoId, memberId])
  @@index([photoId])
  @@index([memberId])
}

model Relationship {
  id        String   @id @default(cuid())
  treeId    String   @map("tree_id")
  memberAId String  @map("member_a_id")
  memberBId String  @map("member_b_id")
  type      String  // parent, child, spouse, sibling
  createdAt DateTime @default(now()) @map("created_at")

  tree    Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  memberA Member @relation("MemberA", fields: [memberAId], references: [id], onDelete: Cascade)
  memberB Member @relation("MemberB", fields: [memberBId], references: [id], onDelete: Cascade)

  @@unique([treeId, memberAId, memberBId, type])
  @@index([treeId])
}

model Invitation {
  id         String    @id @default(cuid())
  treeId     String    @map("tree_id")
  email      String
  role       String    // viewer, editor
  invitedById String   @map("invited_by_id")
  token      String    @unique
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tree     Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([treeId])
  @@index([token])
}

model TreeAccess {
  userId   String @map("user_id")
  treeId   String @map("tree_id")
  role     String // owner, editor, viewer
  joinedAt DateTime @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@id([userId, treeId])
  @@index([userId])
  @@index([treeId])
}
