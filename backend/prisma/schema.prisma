generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")

  ownedTrees   Tree[]         @relation("TreeOwner")
  treeAccess   TreeAccess[]
  sentInvites  Invitation[]   @relation("InvitedBy")
}

model Tree {
  id               String   @id @default(cuid())
  name             String
  ownerId          String   @map("owner_id")
  layoutPositions  Json?    @map("layout_positions")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  owner        User         @relation("TreeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      Member[]
  relationships Relationship[]
  invitations  Invitation[]
  access       TreeAccess[]
}

model Member {
  id        String    @id @default(cuid())
  treeId    String    @map("tree_id")
  name      String
  birthDate DateTime? @map("birth_date")
  deathDate DateTime? @map("death_date")
  bio       String?
  photoUrl  String?   @map("photo_url")
  createdAt DateTime  @default(now()) @map("created_at")

  tree          Tree           @relation(fields: [treeId], references: [id], onDelete: Cascade)
  relsAsA       Relationship[] @relation("MemberA")
  relsAsB       Relationship[] @relation("MemberB")
}

model Relationship {
  id        String   @id @default(cuid())
  treeId    String   @map("tree_id")
  memberAId String  @map("member_a_id")
  memberBId String  @map("member_b_id")
  type      String  // parent, child, spouse, sibling
  createdAt DateTime @default(now()) @map("created_at")

  tree    Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  memberA Member @relation("MemberA", fields: [memberAId], references: [id], onDelete: Cascade)
  memberB Member @relation("MemberB", fields: [memberBId], references: [id], onDelete: Cascade)

  @@unique([treeId, memberAId, memberBId, type])
  @@index([treeId])
}

model Invitation {
  id         String    @id @default(cuid())
  treeId     String    @map("tree_id")
  email      String
  role       String    // viewer, editor
  invitedById String   @map("invited_by_id")
  token      String    @unique
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tree     Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([treeId])
  @@index([token])
}

model TreeAccess {
  userId   String @map("user_id")
  treeId   String @map("tree_id")
  role     String // owner, editor, viewer
  joinedAt DateTime @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@id([userId, treeId])
  @@index([userId])
  @@index([treeId])
}
